SECRET_KEY=dev-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,testserver
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
SITE_URL=http://127.0.0.1:8000
# Public URL used by email clients to load logo/static assets.
# For local browser/email clients, 127.0.0.1 works. For Gmail/Outlook inbox
# tests, use a public HTTPS tunnel/domain because providers cannot fetch localhost.
EMAIL_ASSET_BASE_URL=http://127.0.0.1:8000
PROJECT_EMAIL_SITE_NAME=Gastou, Lembrou!
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
USE_X_FORWARDED_PROTO=False
USE_WHITENOISE=False

# Optional. If omitted, SQLite is used locally.
DATABASE_URL=

# Development default: prints emails in the runserver terminal.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production/SMTP example: switch EMAIL_BACKEND and fill the SMTP fields.
# Use the main project mailbox here. It sends account confirmations,
# payment reminders, legal updates, reports and support notifications.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=principal@gastoulembrou.com.br
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Gastou Lembrou <principal@gastoulembrou.com.br>

# Support mailbox. It receives support form messages and appears as the
# public contact address in legal/privacy pages. Support form replies use
# the logged user's email as Reply-To.
SUPPORT_EMAIL=suporte@gastoulembrou.com.br

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Optional. If omitted, Django uses local memory cache for development.
# For production, prefer Redis in a separated database.
CACHE_URL=
# CACHE_URL=redis://localhost:6379/2
PAYMENT_LIST_CACHE_TIMEOUT=300

MAX_RECEIPT_UPLOAD_MB=10
MAX_STATEMENT_UPLOAD_MB=10
MAX_CREDIT_CARD_STATEMENT_UPLOAD_MB=15
MAX_SUPPORT_SCREENSHOT_MB=5

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. Without a key, intelligent insights use the local fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_SECONDS=30
